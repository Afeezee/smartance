# -----------------------------------------------------------------------------
# Smartance environment variables.
# Copy this file to `.env.local` for development. Never commit `.env.local`.
# -----------------------------------------------------------------------------

# Neon Postgres connection string. Get one at https://console.neon.tech/.
# Use the "Pooled connection" URI when deploying to Vercel.
DATABASE_URL="postgres://user:password@host.neon.tech/smartance?sslmode=require"

# Secret used to sign NextAuth session JWTs. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=""

# The canonical URL of the deployment. Auth.js reads this for OAuth callback
# URLs and secure cookies. In production this is set automatically on Vercel.
NEXTAUTH_URL="http://localhost:3000"

# HMAC secret used to sign rotating QR tokens (Phase 3+). Generate similarly
# to NEXTAUTH_SECRET. MUST be different from NEXTAUTH_SECRET.
QR_TOKEN_SECRET=""

# Groq API key for weekly AI-generated attendance narratives (Phase 6).
# Get one at https://console.groq.com/keys. Leave blank to disable insights.
GROQ_API_KEY=""

# -----------------------------------------------------------------------------
# Admin seed (used by `npm run seed:admin`).
# The seed script is idempotent — running it again resets the admin password.
# -----------------------------------------------------------------------------
ADMIN_EMAIL="admin@tpi.edu.ng"
ADMIN_PASSWORD="change-me-please"
ADMIN_NAME="Smartance Admin"
